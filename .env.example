# Cowork Bench — environment template
# Copy to .env and fill in real values. .env is gitignored.

# === Модель ===
# MODEL_PROVIDER — какой бэкенд использовать.
# Допустимо: openai | anthropic | gemini | deepseek | qwen | openrouter | aihubmix | openai_compatible
# MODEL_NAME — id модели. MODEL_API_KEY / MODEL_API_URL — ключ и эндпоинт
# (URL нужен для openai_compatible / aihubmix).
MODEL_PROVIDER=openai_compatible
MODEL_NAME=your-model-name
MODEL_API_KEY=sk-REPLACE_ME
MODEL_API_URL=https://your-llm-endpoint/v1
LLM_CONTEXT_WINDOW=262144
LLM_STREAM_IDLE_TIMEOUT=300

# === Postgres (Cowork Bench мок-БД) ===
PGHOST=cowork_pg
PGPORT=5432
PGUSER=eigent
PGPASSWORD=camel
PGDATABASE=cowork_gym

# === Пути ===
LOCAL_SERVERS_PATH=/opt/local_servers
PYTHON_BIN=/opt/venv/bin/python3

# === Strands-раннер (опционально, см. docs/STRANDS.md) ===
# Альтернативный phase-aware раннер с изоляцией эталона. Включение:
# AGENT_ENTRY=main_strands.py
# AGENT_PHASE_AWARE=1
# Модель для Strands задаётся через LLM_* (LLM_MODEL обязателен):
# LLM_BASE_URL=https://your-llm-endpoint/v1
# LLM_API_KEY=sk-REPLACE_ME
# LLM_MODEL=your-model-name
# LLM_PARAM_PROFILE=clean          # clean (дефолт, любой hosted API) | vllm (self-hosted vLLM)
# LLM_CONTEXT_WINDOW=131072        # реальное окно модели (Strands подрезает историю до лимита)
# LLM_MAX_TOKENS=32768
# LLM_SSL_VERIFY=true              # false — отключить проверку TLS (самоподписанные серты)

# === Подключение своего раннера (опционально) ===
# По умолчанию используется CAMEL-раннер (main.py) на образе cowork-pack:latest.
# Чтобы подключить свой харнес, укажите путь к его entrypoint внутри /workspace:
# AGENT_ENTRY=path/to/your_runner.py
# Если ваш раннер поддерживает фазы (--phase agent | --phase eval), включите
# изоляцию groundtruth (агент не видит эталон; грейдер запускается отдельно):
# AGENT_PHASE_AWARE=1
# IMAGE=cowork-pack:latest

# === Опционально: HTTP MCP-серверы (если используются) ===
# MCP_HTTP_URLS=
# MCP_HTTP_TIMEOUT=60
