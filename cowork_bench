#!/usr/bin/env bash
# cowork_bench — единая точка входа для Cowork-Bench.
#
# Скрывает повторяющийся бойлерплейт (source .env, AGENT_ENTRY, IMAGE,
# флаги docker). Не требует ничего, кроме docker и bash — Python на хост
# ставить не нужно (всё выполняется внутри контейнеров).
#
# Quickstart:
#   git clone … && cd cowork_gym
#   cp .env.example .env   # вставить LLM_API_KEY
#   ./cowork_bench up      # поднять persistent сервисы (Postgres)
#   ./cowork_bench test-db # smoke миграций
#   ./cowork_bench run rzd-kulinar-team-trip-spb-catering-excel-gcal
#
# См. ./cowork_bench help — полный список команд.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$REPO_ROOT"

# Дефолтный раннер — CAMEL (main.py). Свой раннер подключается через .env:
# AGENT_ENTRY=<путь> (+ AGENT_PHASE_AWARE=1 для изоляции groundtruth).
export IMAGE="${IMAGE:-cowork-pack:latest}"

# Автозагрузка .env (если есть). LLM_API_KEY и т.п. подтянутся.
if [ -f ./.env ]; then
    set -a
    # shellcheck disable=SC1091
    . ./.env
    set +a
fi

# ─── helpers ──────────────────────────────────────────────────────────────────
red()    { printf '\033[31m%s\033[0m\n' "$*"; }
green()  { printf '\033[32m%s\033[0m\n' "$*"; }
cyan()   { printf '\033[36m%s\033[0m\n' "$*"; }

die() { red "$*" >&2; exit 1; }

check_task() {
    local task="$1"
    if [ ! -d "tasks/finalpool/$task" ]; then
        red "задача не найдена: tasks/finalpool/$task" >&2
        local hits
        hits=$(ls tasks/finalpool/ | grep -i "$task" | head -5 || true)
        if [ -n "$hits" ]; then
            echo "возможно вы имели в виду:" >&2
            echo "$hits" | sed 's|^|  |' >&2
        fi
        exit 2
    fi
}

# ─── commands ─────────────────────────────────────────────────────────────────

cmd_up() {
    docker compose up -d "$@"
}

cmd_down() {
    docker compose down "$@"
}

cmd_run() {
    local task="${1:?usage: cowork_bench run TASK [steps]}"
    local steps="${2:-60}"
    check_task "$task"
    bash scripts/run_containerized.sh "$task" "$steps"
}

cmd_stability() {
    local task="${1:?usage: cowork_bench stability TASK [n] [steps]}"
    local n="${2:-5}"
    local steps="${3:-60}"
    check_task "$task"

    local results=() rc summary
    for i in $(seq 1 "$n"); do
        cyan ""
        cyan "[stability] === run $i/$n ==="
        # Захватываем stdout для парсинга, но пробрасываем юзеру в realtime через tee.
        local tmp
        tmp=$(mktemp)
        if bash scripts/run_containerized.sh "$task" "$steps" 2>&1 | tee "$tmp"; then
            rc=0
        else
            rc=${PIPESTATUS[0]}
        fi
        summary=$(grep -E "Итого:.*проверок пройдено" "$tmp" | tail -1 | sed 's|^[[:space:]]*||' || echo "n/a")
        results+=("$i|$rc|${summary:-n/a}")
        rm -f "$tmp"
    done

    cyan ""
    cyan "[stability] === summary ==="
    local fails=0
    for r in "${results[@]}"; do
        local i="${r%%|*}"; local rest="${r#*|}"
        local rc="${rest%%|*}"; local s="${rest#*|}"
        if [ "$rc" = "0" ]; then green "  run $i: exit=$rc  $s"; else red "  run $i: exit=$rc  $s"; fails=$((fails+1)); fi
    done
    if [ "$fails" -gt 0 ]; then
        red "[stability] FAIL — $fails/$n прогонов упало"
        exit 1
    fi
    green "[stability] OK — $n/$n"
}

cmd_bench() {
    local concurrency="${1:-3}"
    local steps="${2:-100}"
    # Раннер, модель и изоляция берутся из окружения (.env уже загружен выше):
    # MODEL_NAME / MODEL_PROVIDER / MODEL_API_* (дефолтный CAMEL) или
    # AGENT_ENTRY (+ AGENT_PHASE_AWARE=1) + LLM_* для своего раннера.
    MAX_STEPS="$steps" bash run_parallel.sh "$concurrency"
}

cmd_test_db() {
    bash scripts/test_db_migration.sh
}

cmd_stop() {
    # Аварийная зачистка после Ctrl+C на bench/stability:
    #   - убивает эфемерные task-контейнеры (cowork-* / agent-* / eval-*) и их per-task PG (pg-*)
    #   - убивает фоновые run_parallel.sh / cowork_bench bench
    #   - удаляет stale lock dumps/.run.lock.d
    # Persistent сервисы (cowork_pg, mcpgateway, ratatoskr_*) НЕ трогает —
    # это управляется через `./cowork_bench down`.
    cyan "[stop] killing task containers (cowork-* / agent-* / eval-*) ..."
    local tcs
    tcs=$(docker ps -a --format '{{.Names}}' 2>/dev/null | grep -E '^(cowork|agent|eval)-' || true)
    if [ -n "$tcs" ]; then
        echo "$tcs" | xargs docker rm -fv >/dev/null 2>&1 || true
        green "  ok ($(echo "$tcs" | wc -l | tr -d ' ') containers)"
    else
        echo "  none"
    fi

    cyan "[stop] killing per-task postgres (pg-*) ..."
    local pgs
    pgs=$(docker ps -aq --filter "name=^pg-" 2>/dev/null | grep -v "^$" || true)
    if [ -n "$pgs" ]; then
        echo "$pgs" | xargs docker rm -fv >/dev/null 2>&1 || true
        green "  ok ($(echo "$pgs" | wc -l | tr -d ' ') containers)"
    else
        echo "  none"
    fi

    cyan "[stop] killing host processes (run_parallel.sh / cowork_bench bench) ..."
    local pids
    pids=$(pgrep -f "run_parallel\.sh|cowork_bench[[:space:]]+bench|cowork_bench[[:space:]]+stability" 2>/dev/null | grep -v "^$" || true)
    if [ -n "$pids" ]; then
        echo "$pids" | xargs kill -9 >/dev/null 2>&1 || true
        green "  ok (pids: $(echo "$pids" | tr '\n' ' '))"
    else
        echo "  none"
    fi

    if [ -d dumps/.run.lock.d ]; then
        cyan "[stop] removing stale lock dumps/.run.lock.d ..."
        rm -rf dumps/.run.lock.d
        green "  ok"
    fi

    green "[stop] clean."
}

cmd_new() {
    # cowork_bench new --from BASE --to NEW [--no-csv]
    # Дёргает scripts/scaffold_ru_task.py через docker (python3 в pack-образе),
    # чтобы не зависеть от системного python.
    if docker image inspect "$IMAGE" >/dev/null 2>&1; then
        docker run --rm \
            -v "$(pwd):/workspace" -w /workspace \
            "$IMAGE" /opt/venv/bin/python3 scripts/scaffold_ru_task.py "$@"
    elif command -v python3 >/dev/null 2>&1; then
        python3 scripts/scaffold_ru_task.py "$@"
    else
        die "ни '$IMAGE' image, ни системный python3 не найдены — нужен хотя бы один"
    fi
}

cmd_tasks() {
    local pattern="${1:-}"
    if [ -n "$pattern" ]; then
        ls tasks/finalpool/ | grep -i "$pattern" || true
    else
        ls tasks/finalpool/
    fi
    cyan ""
    cyan "$(ls tasks/finalpool/ | wc -l | tr -d ' ') task(s) total"
}

cmd_logs() {
    local task="${1:?usage: cowork_bench logs TASK}"
    local d="dumps/$task"
    [ -d "$d" ] || die "нет дампов для $task в $d"
    # shellcheck disable=SC2012
    ls -1d "$d"/*/ 2>/dev/null | sort | tail -1
}

cmd_help() {
    cat <<'EOF'
cowork_bench — единая точка входа для Cowork-Bench.

Commands:
  up                              Поднять persistent сервисы (Postgres, ...)
  down                            Остановить persistent сервисы
  run    TASK [steps=60]          Один прогон одной задачи
  stability TASK [n=5] [steps=60] N прогонов, сводка PASS/FAIL
  bench  [concurrency=3] [steps=100]
                                  Параллельный бенч всех задач
  test-db                         Smoke-test миграций db/* на свежем PG
  stop                            Аварийно убить task-контейнеры, per-task PG и фоновый bench/stability
  new --from BASE --to NEW        Скаффолд русифицированной задачи
  tasks  [pattern]                Список задач (опционально по подстроке)
  logs   TASK                     Путь к последнему dump'у задачи
  help                            Эта справка

Examples:
  ./cowork_bench up
  ./cowork_bench run rzd-kulinar-team-trip-spb-catering-excel-gcal
  ./cowork_bench stability rzd-kulinar-team-trip-spb-catering-excel-gcal 5
  ./cowork_bench bench 3
  ./cowork_bench new --from 12306-foo-bar --to rzd-foo-bar
  ./cowork_bench tasks rzd-
EOF
}

# ─── dispatch ─────────────────────────────────────────────────────────────────
cmd="${1:-help}"
shift || true

case "$cmd" in
    up)         cmd_up "$@" ;;
    down)       cmd_down "$@" ;;
    run)        cmd_run "$@" ;;
    stability)  cmd_stability "$@" ;;
    bench)      cmd_bench "$@" ;;
    test-db)    cmd_test_db "$@" ;;
    stop)       cmd_stop "$@" ;;
    new)        cmd_new "$@" ;;
    tasks)      cmd_tasks "$@" ;;
    logs)       cmd_logs "$@" ;;
    help|-h|--help) cmd_help ;;
    *)          red "unknown command: $cmd" >&2; cmd_help; exit 2 ;;
esac
